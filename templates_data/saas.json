    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{app.name}}</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-black text-white overflow-x-hidden\">\n  <div class=\"relative bg-gradient-to-b from-purple-900/40 to-black pt-20 pb-32\">\n    <div class=\"max-w-7xl mx-auto px-6 lg:px-8 text-center\">\n      <div class=\"inline-flex items-center space-x-2 bg-white/10 rounded-full px-4 py-1.5 mb-8 border border-white/20\">\n        <span class=\"text-xs font-semibold uppercase tracking-wider text-purple-300\">New Release 2.0</span>\n      </div>\n      <h1 class=\"text-5xl md:text-7xl font-bold tracking-tight mb-6\">\n        {{app.name}}\n      </h1>\n      <p class=\"text-xl md:text-2xl text-gray-400 mb-10 max-w-2xl mx-auto\">\n        {{app.tagline}}\n      </p>\n      <button class=\"bg-purple-600 hover:bg-purple-500 text-white px-8 py-4 rounded-full font-bold text-lg transition-colors shadow-[0_0_30px_rgba(147,51,234,0.3)]\">\n        {{app.cta}}\n      </button>\n      \n      <div class=\"mt-20 flex justify-center\">\n        <div class=\"relative w-64 h-[500px] bg-gray-900 border-[8px] border-gray-800 rounded-[2.5rem] shadow-2xl overflow-hidden flex items-center justify-center\">\n          <!-- Phone Mockup Frame -->\n          <div class=\"absolute top-0 w-32 h-6 bg-gray-800 rounded-b-3xl\"></div>\n          <span class=\"text-gray-600 text-sm font-medium\">App Interface</span>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"bg-black py-24 border-t border-white/10\">\n    <div class=\"max-w-7xl mx-auto px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12\">\n      {{#each features}}\n      <div class=\"text-left\">\n        <div class=\"w-10 h-10 rounded-full bg-purple-900/50 flex items-center justify-center mb-6\">\n           <div class=\"w-4 h-4 rounded-full bg-purple-500\"></div>\n        </div>\n        <h3 class=\"text-xl font-bold mb-3 text-gray-100\">{{this.title}}</h3>\n        <p class=\"text-gray-400 leading-relaxed\">{{this.desc}}</p>\n      </div>\n      {{/each}}\n    </div>\n  </div>\n</body>\n</html>\n"
