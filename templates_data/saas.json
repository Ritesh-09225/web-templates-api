    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{hero.title}}</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap\" rel=\"stylesheet\">\n  <style> body { font-family: 'Inter', sans-serif; } </style>\n</head>\n<body class=\"bg-white text-gray-900\">\n  <nav class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex justify-between items-center\">\n    <div class=\"font-bold text-xl tracking-tighter\">SaaS.Inc</div>\n    <div class=\"flex gap-4\">\n      <a href=\"#\" class=\"text-gray-600 hover:text-gray-900 px-4 py-2\">Login</a>\n      <a href=\"#\" class=\"bg-black text-white px-5 py-2 rounded-md font-medium hover:bg-gray-800\">{{hero.primary_cta}}</a>\n    </div>\n  </nav>\n\n  <header class=\"pt-20 pb-32 text-center max-w-5xl mx-auto px-4\">\n    <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tight mb-8 leading-tight\">{{hero.title}}</h1>\n    <p class=\"text-xl md:text-2xl text-gray-500 mb-12 max-w-3xl mx-auto leading-relaxed\">{{hero.description}}</p>\n    <div class=\"flex flex-col sm:flex-row justify-center gap-4\">\n      <a href=\"#\" class=\"bg-blue-600 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-blue-700 transition\">{{hero.primary_cta}}</a>\n      <a href=\"#\" class=\"bg-gray-100 text-gray-900 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-gray-200 transition\">{{hero.secondary_cta}}</a>\n    </div>\n    <div class=\"mt-20 w-full h-[500px] bg-gray-100 rounded-3xl border border-gray-200 shadow-2xl flex items-center justify-center\">\n      <span class=\"text-gray-400 font-medium text-lg\">[App Dashboard Preview]</span>\n    </div>\n  </header>\n\n  <section class=\"py-24 bg-gray-50\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12\">\n        {{#each benefits}}\n        <div class=\"text-left\">\n          <div class=\"w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-6 font-bold text-xl\">✓</div>\n          <h3 class=\"text-2xl font-bold mb-4\">{{this.heading}}</h3>\n          <p class=\"text-gray-600 text-lg leading-relaxed\">{{this.text}}</p>\n        </div>\n        {{/each}}\n      </div>\n    </div>\n  </section>\n</body>\n</html>\n"
