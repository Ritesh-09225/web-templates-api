  {
    "id": "b1a134d1-12c5-4d7a-b5e1-5e5893f4e1f7",
    "name": "Vibrant & Playful SaaS V3",
    "framework": "tailwind-html",
    "json_schema": {
      "type": "object",
      "properties": {
        "header": {
