            "main_text": { "type": "string" },
            "sub_text": { "type": "string" },
            "button_text": { "type": "string" }
          },
          "required": ["badge", "main_text", "sub_text", "button_text"],
          "additionalProperties": false
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "desc": { "type": "string" }
            },
            "required": ["title", "desc"],
            "additionalProperties": false
          },
          "minItems": 3,
          "maxItems": 3
        }
