      "required": ["header", "highlights"],
      "additionalProperties": false
    },
    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{header.main_text}}</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n  <style> body { font-family: 'Outfit', sans-serif; } </style>\n</head>\n<body class=\"bg-rose-50 text-slate-800\">\n  <div class=\"min-h-screen bg-gradient-to-br from-rose-100 via-purple-100 to-amber-100\">\n    <nav class=\"p-6 flex justify-between items-center max-w-7xl mx-auto\">\n      <div class=\"font-black text-3xl text-rose-600\">YayApp!</div>\n      <button class=\"bg-white text-rose-600 font-bold py-2 px-6 rounded-full shadow-sm hover:shadow-md transition-all\">Login</button>\n    </nav>\n\n    <main class=\"max-w-5xl mx-auto px-6 py-20 text-center\">\n      <span class=\"inline-block py-1 px-4 rounded-full bg-white text-rose-500 font-bold text-sm mb-8 shadow-sm border border-rose-100\">\n        ✨ {{header.badge}}\n      </span>\n      <h1 class=\"text-6xl md:text-8xl font-black mb-8 leading-tight text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-purple-600\">\n        {{header.main_text}}\n      </h1>\n      <p class=\"text-xl md:text-3xl text-slate-600 mb-12 font-medium max-w-3xl mx-auto\">\n        {{header.sub_text}}\n      </p>\n      <button class=\"bg-rose-500 hover:bg-rose-600 text-white text-xl font-bold py-5 px-12 rounded-full shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-300\">\n        {{header.button_text}}\n      </button>\n    </main>\n\n    <section class=\"max-w-6xl mx-auto px-6 pb-24\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n        {{#each highlights}}\n        <div class=\"bg-white/60 backdrop-blur-md p-10 rounded-3xl border border-white/50 shadow-xl hover:scale-105 transition-transform duration-300\">\n          <h3 class=\"text-2xl font-bold mb-4 text-purple-700\">{{this.title}}</h3>\n          <p class=\"text-slate-600 text-lg\">{{this.desc}}</p>\n        </div>\n        {{/each}}\n      </div>\n    </section>\n  </div>\n</body>\n</html>\n"
  },
  {
    "id": "e2f7b889-1300-47b2-850c-e26b1c4125b2",
    "name": "Enterprise Professional SaaS V4",
    "framework": "tailwind-html",
    "json_schema": {
      "type": "object",
      "properties": {
        "content": {
          "type": "object",
          "properties": {
            "headline": { "type": "string" },
            "body": { "type": "string" },
            "cta_primary": { "type": "string" }
          },
          "required": ["headline", "body", "cta_primary"],
          "additionalProperties": false
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "number": { "type": "string" },
              "label": { "type": "string" }
            },
            "required": ["number", "label"],
            "additionalProperties": false
          },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["content", "stats"],
      "additionalProperties": false
    },
    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{content.headline}}</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <link href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n  <style> body { font-family: 'Roboto', sans-serif; } </style>\n</head>\n<body class=\"bg-slate-50 text-slate-900\">\n  <nav class=\"bg-white border-b border-slate-200 sticky top-0 z-50\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex justify-between items-center\">\n      <div class=\"text-2xl font-bold text-blue-900 tracking-tight\">EnterpriseCorp</div>\n      <button class=\"bg-blue-600 text-white px-5 py-2 rounded font-medium hover:bg-blue-700\">Contact Sales</button>\n    </div>\n  </nav>\n\n  <header class=\"bg-blue-900 text-white pt-24 pb-32\">\n    <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center\">\n      <div>\n        <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6\">\n          {{content.headline}}\n        </h1>\n        <p class=\"text-lg md:text-xl text-blue-200 mb-10 leading-relaxed\">\n          {{content.body}}\n        </p>\n        <div class=\"flex flex-wrap gap-4\">\n          <button class=\"bg-white text-blue-900 px-8 py-4 rounded font-bold hover:bg-blue-50 transition-colors shadow-lg\">\n            {{content.cta_primary}}\n          </button>\n          <button class=\"border border-blue-400 text-white px-8 py-4 rounded font-bold hover:bg-blue-800 transition-colors\">\n            Read Documentation\n          </button>\n        </div>\n      </div>\n      <div class=\"hidden md:block\">\n        <div class=\"bg-slate-800 rounded-lg p-6 shadow-2xl border border-slate-700 h-[400px] flex items-center justify-center\">\n           <span class=\"text-slate-500 font-mono\">// Enterprise Data Visualization</span>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  <section class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16\">\n    <div class=\"bg-white rounded-xl shadow-xl border border-slate-100 p-10\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 divide-y md:divide-y-0 md:divide-x divide-slate-200\">\n        {{#each stats}}\n        <div class=\"text-center pt-8 md:pt-0\">\n          <div class=\"text-4xl md:text-5xl font-bold text-blue-600 mb-2\">{{this.number}}</div>\n          <div class=\"text-slate-500 font-medium uppercase tracking-wide text-sm\">{{this.label}}</div>\n        </div>\n        {{/each}}\n      </div>\n    </div>\n  </section>\n</body>\n</html>\n"
  },
  {
