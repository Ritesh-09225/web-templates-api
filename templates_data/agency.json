    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{company.name}} | PR</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-[#f4f1ea] text-[#2c2c2c] font-serif\">\n  <div class=\"max-w-5xl mx-auto px-6 py-12\">\n    <header class=\"flex flex-col items-center text-center mb-20\">\n      <div class=\"text-sm uppercase tracking-widest mb-8 font-sans font-semibold\">{{company.name}}</div>\n      <h1 class=\"text-5xl md:text-6xl font-normal leading-tight max-w-3xl\">{{company.headline}}</h1>\n    </header>\n    <section class=\"border-t border-[#d1cec5] pt-16\">\n      <h2 class=\"text-center text-xs uppercase tracking-widest font-sans font-semibold mb-12 text-gray-500\">Trusted By</h2>\n      <div class=\"flex flex-wrap justify-center gap-8 md:gap-16 opacity-70\">\n        {{#each clients}}\n        <div class=\"text-xl md:text-2xl font-bold tracking-tight\">{{this.name}}</div>\n        {{/each}}\n      </div>\n    </section>\n  </div>\n</body>\n</html>\n"
  },
  {
    "id": "04baf8e4-4567-4def-6543-def234567890",
    "name": "SEO & Growth Agency",
    "framework": "tailwind-html",
    "json_schema": {
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" }
          },
          "required": ["title", "subtitle"],
          "additionalProperties": false
        },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" }
            },
            "required": ["value", "label"],
            "additionalProperties": false
          },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["hero", "stats"],
      "additionalProperties": false
    },
    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Growth Agency</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-white text-gray-800 font-sans\">\n  <main>\n    <section class=\"bg-emerald-600 text-white py-24 px-6\">\n      <div class=\"max-w-4xl mx-auto text-center\">\n        <h1 class=\"text-5xl md:text-6xl font-bold mb-6\">{{hero.title}}</h1>\n        <p class=\"text-xl md:text-2xl text-emerald-100 mb-10\">{{hero.subtitle}}</p>\n        <button class=\"bg-white text-emerald-600 font-bold py-3 px-8 rounded-full shadow-lg hover:bg-emerald-50 transition\">Get a Free Audit</button>\n      </div>\n    </section>\n    <section class=\"py-20 px-6\">\n      <div class=\"max-w-5xl mx-auto\">\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n          {{#each stats}}\n          <div class=\"text-center p-8 border-2 border-gray-100 rounded-2xl\">\n            <div class=\"text-4xl font-black text-emerald-600 mb-2\">{{this.value}}</div>\n            <div class=\"text-gray-500 font-medium uppercase tracking-wide\">{{this.label}}</div>\n          </div>\n          {{/each}}\n        </div>\n      </div>\n    </section>\n  </main>\n</body>\n</html>\n"
  },
