[
  {
    "id": "d1e7c5b1-1234-4abc-9876-abcdef123456",
    "name": "Digital Marketing Agency",
    "framework": "tailwind-html",
    "json_schema": {
      "type": "object",
      "properties": {
        "agency": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "tagline": { "type": "string" },
            "about": { "type": "string" }
          },
          "required": ["name", "tagline", "about"],
          "additionalProperties": false
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["title", "description"],
            "additionalProperties": false
          },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "required": ["agency", "services"],
      "additionalProperties": false
    },
    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{agency.name}} - Digital Marketing</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-gray-50 text-gray-900 font-sans\">\n  <header class=\"bg-white shadow-sm py-6\">\n    <div class=\"max-w-7xl mx-auto px-4 flex justify-between items-center\">\n      <h1 class=\"text-2xl font-bold text-indigo-600\">{{agency.name}}</h1>\n      <nav class=\"space-x-4\">\n        <a href=\"#\" class=\"text-gray-600 hover:text-indigo-600\">Services</a>\n        <a href=\"#\" class=\"text-gray-600 hover:text-indigo-600\">About</a>\n        <a href=\"#\" class=\"bg-indigo-600 text-white px-4 py-2 rounded-md hover:bg-indigo-700\">Contact Us</a>\n      </nav>\n    </div>\n  </header>\n  <section class=\"py-20 text-center px-4\">\n    <h2 class=\"text-5xl font-extrabold tracking-tight text-gray-900 mb-4\">{{agency.tagline}}</h2>\n    <p class=\"mt-4 max-w-2xl text-xl text-gray-500 mx-auto\">{{agency.about}}</p>\n    <div class=\"mt-8\">\n      <a href=\"#\" class=\"bg-indigo-600 text-white px-8 py-3 rounded-md text-lg font-medium hover:bg-indigo-700\">Get Started</a>\n    </div>\n  </section>\n  <section class=\"py-16 bg-white\">\n    <div class=\"max-w-7xl mx-auto px-4\">\n      <h3 class=\"text-3xl font-bold text-center mb-12\">Our Services</h3>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n        {{#each services}}\n        <div class=\"p-6 border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-shadow\">\n          <h4 class=\"text-xl font-bold mb-2\">{{this.title}}</h4>\n          <p class=\"text-gray-600\">{{this.description}}</p>\n        </div>\n        {{/each}}\n      </div>\n    </div>\n  </section>\n</body>\n</html>\n"
  },
  {
    "id": "e2f8d6c2-2345-4bcd-8765-bcdef0123456",
    "name": "Creative Design Studio",
    "framework": "tailwind-html",
    "json_schema": {
      "type": "object",
      "properties": {
        "studio": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "vision": { "type": "string" }
          },
          "required": ["name", "vision"],
          "additionalProperties": false
        },
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "category": { "type": "string" }
            },
            "required": ["name", "category"],
            "additionalProperties": false
          },
          "minItems": 4,
          "maxItems": 4
        }
      },
      "required": ["studio", "projects"],
      "additionalProperties": false
    },
    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{studio.name}} - Creative Studio</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-black text-white font-mono\">\n  <nav class=\"p-8 flex justify-between items-center\">\n    <div class=\"text-2xl font-bold tracking-tighter\">{{studio.name}}</div>\n    <a href=\"mailto:hello@studio.com\" class=\"border-b border-white hover:text-gray-400 hover:border-gray-400 transition-colors\">Let's Talk</a>\n  </nav>\n  <header class=\"px-8 py-24 md:py-32\">\n    <h1 class=\"text-4xl md:text-7xl font-bold leading-tight max-w-4xl\">{{studio.vision}}</h1>\n  </header>\n  <section class=\"px-8 py-16\">\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\">\n      {{#each projects}}\n      <div class=\"group cursor-pointer\">\n        <div class=\"aspect-[4/3] bg-gray-900 mb-4 overflow-hidden rounded-lg\">\n          <div class=\"w-full h-full bg-gray-800 group-hover:scale-105 transition-transform duration-500\"></div>\n        </div>\n        <h3 class=\"text-2xl font-bold mb-1\">{{this.name}}</h3>\n        <p class=\"text-gray-500 uppercase text-sm tracking-widest\">{{this.category}}</p>\n      </div>\n      {{/each}}\n    </div>\n  </section>\n</body>\n</html>\n"
  },
  {
