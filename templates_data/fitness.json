    "raw_html": "\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{program.title}}</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n</head>\n<body class=\"bg-indigo-600 text-white font-sans\">\n  <div class=\"max-w-4xl mx-auto px-6 py-20 text-center\">\n    <div class=\"inline-block bg-white text-indigo-600 font-bold px-4 py-1 rounded-full mb-8 text-sm\">\n      100% Online Coaching\n    </div>\n    <h1 class=\"text-5xl md:text-7xl font-extrabold mb-6 tracking-tight\">\n      {{program.title}}\n    </h1>\n    <p class=\"text-2xl text-indigo-200 mb-12\">\n      Focus: <span class=\"text-white font-semibold\">{{program.focus}}</span>\n    </p>\n    \n    <div class=\"bg-white text-indigo-900 rounded-3xl p-8 md:p-12 text-left shadow-2xl\">\n      <h2 class=\"text-2xl font-bold mb-8 text-center\">What's Included in the App</h2>\n      <ul class=\"grid grid-cols-1 md:grid-cols-2 gap-6 mb-10\">\n        {{#each benefits}}\n        <li class=\"flex items-start\">\n          <svg class=\"w-6 h-6 text-green-500 mr-3 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\"></path></svg>\n          <span class=\"font-medium\">{{this.benefit}}</span>\n        </li>\n        {{/each}}\n      </ul>\n      <button class=\"w-full bg-indigo-600 text-white font-bold text-xl py-4 rounded-xl hover:bg-indigo-700 shadow-lg\">\n        Start Your Journey\n      </button>\n    </div>\n  </div>\n</body>\n</html>\n"
